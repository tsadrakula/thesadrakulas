# --- RSVP writes: Google Apps Script web app ---
# Reads (name lookup) use the committed mirror in lib/rsvp/guests.ts — no env needed.
# Writes POST to the deployed Apps Script /exec URL. See docs/rsvp-apps-script-setup.md
# for how to deploy the script, set the shared token, and fill these in.
# Leave both blank to run lookups locally without writing (dev mode).
RSVP_APPS_SCRIPT_URL=
RSVP_APPS_SCRIPT_TOKEN=
