# Local mock — set true to skip Google Sheets and use lib/rsvp/mock.ts.
# Defaults to true when RSVP_SHEET_ID is unset.
RSVP_USE_MOCK=true

# --- Production: Google Sheets RSVP ---
# 1. Create a service account in Google Cloud, download the JSON key.
# 2. Share the sheet with the service account email (Editor).
# 3. Paste the JSON below as a single-line string.
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# The Sheet ID (the part of the URL after /d/ and before /edit).
# RSVP_SHEET_ID=
